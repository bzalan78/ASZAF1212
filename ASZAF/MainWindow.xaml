<Window x:Class="ASZAF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ASZAF"
         Title="Doohickey Corporations"
 Width="1100"
 Height="500"
 WindowStartupLocation="CenterScreen"
 WindowState="Maximized"
 mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary Source="Resources/Dictionary1.xaml" />
    </Window.Resources>
    <DockPanel Background="LightPink">
        <StackPanel Height="55" DockPanel.Dock="Top">
            <TextBlock
            FontWeight="ExtraBold"
                FontSize="40"
            Foreground="MediumPurple"
            Text="Doohickey Corporations"
            TextAlignment="Center" />
        </StackPanel>
        <StackPanel
         
        Width="200"
        Background="MediumPurple"
        DockPanel.Dock="Left">
            <ListView Margin="8" >
                <ListViewItem
                x:Name="UserMenu"
                Content="Users"
                MouseLeftButtonUp="UserMenu_MouseLeftButtonUp"
                Style="{StaticResource ResourceKey=ListItemStyle}" />
                <ListViewItem
                x:Name="CustomerMenu"
                Content="Customers"
                MouseLeftButtonUp="CustomerMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}"
                />
                <ListViewItem
                x:Name="ProductMenu"
                Content="Products"
                MouseLeftButtonUp="ProductMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}"
                />
               
                <ListViewItem
                x:Name="kilepesMenu"
                Background="Red"
                Content="Bezárás"
                Foreground="White"
               MouseLeftButtonUp="kilepesMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}"
                />
            </ListView>
        </StackPanel>
        <StackPanel x:Name="feladatPanel" DockPanel.Dock="Right" />
    </DockPanel>
</Window>
