<UserControl x:Class="ASZAF.UserControls.UserControlProducts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>

        <DataGrid x:Name="datagridProducts"
                  Width="1100"
                  Height="600"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID"/>
                <DataGridTextColumn Binding="{Binding Name}" Header="Name"/>
                <DataGridTextColumn Binding="{Binding Description}" Header="Description"/>
                <DataGridTextColumn Binding="{Binding Price}" Header="Price"/>
                <DataGridTextColumn Binding="{Binding StockQuantity}" Header="Stock"/>
                <DataGridTextColumn Binding="{Binding Category}" Header="Category"/>
                <DataGridTextColumn Binding="{Binding Brand}" Header="Brand"/>
                <DataGridTextColumn Binding="{Binding Weight}" Header="Weight"/>
                <DataGridCheckBoxColumn Binding="{Binding IsAvailable}" Header="Available"/>
                <DataGridTextColumn Binding="{Binding CreatedAt}" Header="Created"/>
            </DataGrid.Columns>

        </DataGrid>

        <WrapPanel Margin="130,10,130,0">

            <StackPanel Width="300" Background="LightGray">

                <TextBlock>Name:</TextBlock>
                <TextBox x:Name="nameText"/>

                <TextBlock>Description:</TextBlock>
                <TextBox x:Name="descriptionText"/>

                <TextBlock>Price:</TextBlock>
                <TextBox x:Name="priceText"/>

                <TextBlock>Stock:</TextBlock>
                <TextBox x:Name="stockText"/>

                <TextBlock>Category:</TextBlock>
                <TextBox x:Name="categoryText"/>

                <TextBlock>Brand:</TextBlock>
                <TextBox x:Name="brandText"/>

            </StackPanel>

            <StackPanel>
                <Button Width="200"
                        Content="Save"
                        Background="Green"
                        Foreground="White"/>

                <Button Width="200"
                        Content="Delete"
                        Background="Red"
                        Foreground="White"
                        Visibility="Hidden"/>

                <Button Width="200"
                        Content="Modify"
                        Background="Yellow"
                        Visibility="Hidden"/>
            </StackPanel>

        </WrapPanel>

    </StackPanel>
</UserControl>
