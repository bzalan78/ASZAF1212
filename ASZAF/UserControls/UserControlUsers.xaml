<UserControl x:Class="ASZAF.UserControls.UserControlUsers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>

        <DataGrid x:Name="datagridUsers"
                  Width="1100"
                  Height="600"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionChanged="datagridUsers_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID"/>
                <DataGridTextColumn Binding="{Binding Username}" Header="Username"/>
                <DataGridTextColumn Binding="{Binding Email}" Header="Email"/>
                <DataGridTextColumn Binding="{Binding PasswordHash}" Header="Password"/>
                <DataGridTextColumn Binding="{Binding FirstName}" Header="First Name"/>
                <DataGridTextColumn Binding="{Binding LastName}" Header="Last Name"/>
                <DataGridTextColumn Binding="{Binding CreatedAt}" Header="Created"/>
                <DataGridCheckBoxColumn Binding="{Binding IsActive}" Header="Active"/>
                <DataGridTextColumn Binding="{Binding Role}" Header="Role"/>
            </DataGrid.Columns>

        </DataGrid>

        <WrapPanel Margin="130,10,130,0">

            <StackPanel Width="300" Background="LightGray">
                <TextBlock>Username:</TextBlock>
                <TextBox x:Name="usernameText"/>

                <TextBlock>Email:</TextBlock>
                <TextBox x:Name="emailText"/>

                <TextBlock>Password:</TextBlock>
                <PasswordBox x:Name="passwordText"/>

                <TextBlock>First Name:</TextBlock>
                <TextBox x:Name="firstNameText"/>

                <TextBlock>Last Name:</TextBlock>
                <TextBox x:Name="lastNameText"/>

                <TextBlock>Role:</TextBlock>
                <TextBox x:Name="roleText"/>
            </StackPanel>

            <StackPanel>
                <Button x:Name="mentesBtn"
                        Width="200"
                        Content="Save"
                        Background="Green"
                        Foreground="White"/>

                <Button x:Name="torlesBtn"
                        Width="200"
                        Content="Delete"
                        Background="Red"
                        Foreground="White"
                        Visibility="Hidden"/>

                <Button x:Name="modBtn"
                        Width="200"
                        Content="Modify"
                        Background="Yellow"
                        Visibility="Hidden"/>
            </StackPanel>

        </WrapPanel>

    </StackPanel>
</UserControl>
